# Ops DB (staff, auth, materials, pricing) — Neon pooled + direct
OPS_DATABASE_URL=
OPS_DIRECT_URL=

# PII DB (leads, ingest keys). Local / seed / migrate only — do NOT put raw
# PII_DATABASE_URL on Vercel. Production resolves via CLIENT_DB_SECRET_ARN.
PII_DATABASE_URL=
PII_DIRECT_URL=

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Client idle timeout (minutes). Must stay below Better Auth expiresIn (60). Default 45.
# NEXT_PUBLIC_SESSION_IDLE_MINUTES=45

# Optional: public lead ingest shared secret (server-to-server from marketing site)
INGEST_SERVER_SECRET=

# Seed (npm run db:seed) — local only
SEED_ADMIN_EMAIL=
SEED_ADMIN_NAME=
SEED_ADMIN_PASSWORD=

# Local AWS CLI (Smoky Peak account — for IAM/Secrets Manager ops, not required for next dev)
# Expected account: 084000526828 (user Smoky_Peak_Services). Region: us-east-2.
# Put keys in ~/.aws [default]; cousin/Altitude Network uses --profile altitude (501804115142).
# AWS_ACCOUNT_ID=084000526828
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-2
# AWS_ROLE_ARN=arn:aws:iam::084000526828:role/VercelPortalPaymentsInvoke

# --- Vercel (.env.vercel) vs local ---
# On Vercel / sync from .env.vercel:
#   OPS_DATABASE_URL, OPS_DIRECT_URL, BETTER_AUTH_SECRET, BETTER_AUTH_URL,
#   NEXT_PUBLIC_APP_URL, INGEST_SERVER_SECRET (optional),
#   CLIENT_DB_SECRET_ARN, AWS_ROLE_ARN, AWS_REGION (PII via Secrets Manager + OIDC)
# Local only (.env.local):
#   PII_*, SEED_*, AWS_* (CLI ops), future STRIPE_SECRET / Upstash
# Never on Vercel portal process:
#   STRIPE_SECRET_KEY (payments Lambda later), raw PII_DATABASE_URL, Upstash (later)
#
# Sync example:
#   powershell -File scripts/sync-vercel-env.ps1 -EnvFile .env.vercel -Keys OPS_DATABASE_URL,BETTER_AUTH_SECRET,BETTER_AUTH_URL,NEXT_PUBLIC_APP_URL,CLIENT_DB_SECRET_ARN,AWS_ROLE_ARN,AWS_REGION
