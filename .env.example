NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: public lead ingest shared secret (server-to-server from marketing site)
INGEST_SERVER_SECRET=

# Seed (npm run db:seed)
SEED_ADMIN_EMAIL=
SEED_ADMIN_NAME=
SEED_ADMIN_PASSWORD=
