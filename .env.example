# Ops DB (staff, jobs, tickets, auth) — Neon pooled + direct
OPS_DATABASE_URL=
OPS_DIRECT_URL=

# PII DB (customers, leads, locations). Leave unset in local monolith mode to fall back to OPS_*.
# Local / seed only for now — do NOT put raw PII_DATABASE_URL on Vercel until CLIENT_DB_SECRET_ARN is wired.
PII_DATABASE_URL=
PII_DIRECT_URL=

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: public lead ingest shared secret (server-to-server from marketing site)
INGEST_SERVER_SECRET=

# Seed (npm run db:seed) — local only
SEED_ADMIN_EMAIL=
SEED_ADMIN_NAME=
SEED_ADMIN_PASSWORD=

# --- Vercel (.env.vercel) vs local ---
# On Vercel / sync from .env.vercel:
#   OPS_DATABASE_URL, OPS_DIRECT_URL, BETTER_AUTH_SECRET, BETTER_AUTH_URL,
#   NEXT_PUBLIC_APP_URL, INGEST_SERVER_SECRET (optional)
#   Later: CLIENT_DB_SECRET_ARN, AWS_ROLE_ARN, AWS_REGION (PII via Secrets Manager)
# Local only (.env.local):
#   PII_*, SEED_*, future STRIPE_SECRET / Upstash
# Never on Vercel portal process:
#   STRIPE_SECRET_KEY (payments Lambda), raw PII_DATABASE_URL (until SM), Upstash (later)
#
# Sync example:
#   powershell -File scripts/sync-vercel-env.ps1 -EnvFile .env.vercel -Keys OPS_DATABASE_URL,BETTER_AUTH_SECRET,BETTER_AUTH_URL,NEXT_PUBLIC_APP_URL
