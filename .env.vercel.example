# Vercel upload template — KEY NAMES ONLY (fill locally; file is gitignored as .env.vercel)
# Copy to .env.vercel and set real values. Sync with scripts/sync-vercel-env.ps1
#
# Reuse the same CLIENT_DB_SECRET_ARN / AWS_ROLE_ARN as the original SPS Portal
# (sps/clients-db/* + Vercel OIDC role). Do NOT set raw PII_DATABASE_URL here.
# Ensure this Vercel project's OIDC trust can assume AWS_ROLE_ARN (extend the
# role trust if it is project-scoped to the old portal only).

OPS_DATABASE_URL=
OPS_DIRECT_URL=

BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://portal.smokypeak.tech
NEXT_PUBLIC_APP_URL=https://portal.smokypeak.tech

# Optional until ingest callers are live on this deploy
INGEST_SERVER_SECRET=

# Geoapify (CRM address autocomplete + static maps). Server-only.
GEOAPIFY_API_KEY=

# PII via Secrets Manager (OIDC) — same ARNs as original SPS Portal
CLIENT_DB_SECRET_ARN=
AWS_ROLE_ARN=
AWS_REGION=us-east-2
