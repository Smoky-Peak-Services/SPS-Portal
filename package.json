{
  "name": "sps-portal-2",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "next dev",
    "build": "cross-env NEXT_TELEMETRY_DISABLED=1 prisma generate && npm run db:generate:pii && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:schema-guard": "tsx --test src/features/accounting/ops-pii-schema-guard.test.ts",
    "test:materials-io": "tsx --test src/features/materials/io.test.ts",
    "test:materials-attribute-io": "tsx --test src/features/materials/attribute-io.test.ts",
    "test:materials-tax": "tsx --test src/features/materials/tax.test.ts",
    "format": "prettier --write .",
    "db:generate": "prisma generate",
    "db:generate:pii": "prisma generate --schema=prisma/pii/schema.prisma --config=prisma/pii/prisma.config.ts",
    "db:migrate": "node --env-file=.env.local ./node_modules/prisma/build/index.js migrate dev",
    "db:migrate:pii": "node --env-file=.env.local ./node_modules/prisma/build/index.js migrate deploy --schema=prisma/pii/schema.prisma --config=prisma/pii/prisma.config.ts && npm run sync:divisions-pii",
    "db:push": "node --env-file=.env.local ./node_modules/prisma/build/index.js db push",
    "db:push:pii": "node --env-file=.env.local ./node_modules/prisma/build/index.js db push --schema=prisma/pii/schema.prisma --config=prisma/pii/prisma.config.ts",
    "sync:divisions-pii": "tsx --env-file=.env.local scripts/sync-divisions-to-pii.ts",
    "sync:attribute-lists": "tsx --env-file=.env.local scripts/sync-attribute-lists.ts",
    "ensure:core-assignments": "tsx --env-file=.env.local scripts/ensure-core-assignments.ts",
    "write:attribute-lists-fixture": "tsx scripts/write-attribute-lists-fixture.ts",
    "db:seed": "tsx --env-file=.env.local prisma/seed.ts",
    "db:admin-doctor": "tsx --env-file=.env.local prisma/admin-doctor.ts"
  },
  "prisma": {
    "seed": "tsx --env-file=.env.local prisma/seed.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "5.4.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.2.4",
    "better-auth": "1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "lucide-react": "^1.25.0",
    "luxon": "^3.7.2",
    "next": "16.2.10",
    "pg": "^8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.82.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/luxon": "^3.7.2",
    "@types/node": "^24.10.9",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.0",
    "eslint-config-next": "16.2.10",
    "postcss": "^8.5.10",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "prisma": "7.8.0",
    "tailwindcss": "3.4.19",
    "tsx": "^4.23.1",
    "typescript": "5.9.3"
  }
}
