// SPS Portal 2.0 — ops-tier schema (auth + org + materials catalog).
// Customer / lead PII lives in prisma/pii/schema.prisma (separate Neon project).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  staff
  field
  sales
}

enum Segment {
  COMMERCIAL
  RESIDENTIAL
  STR
}

enum MaterialAttributeInputType {
  SELECT
  MULTISELECT
  TEXT
  NUMBER
  BOOLEAN
}

enum MaterialTaxProfile {
  REAL_PROPERTY
  TPP
}

// ---------- Better-Auth core ----------

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  phone         String?
  role          Role     @default(staff)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions    Session[]
  accounts    Account[]
  memberships DivisionMembership[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// ---------- Division layer ----------

model Division {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  segments  String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships     DivisionMembership[]
  materialDomains MaterialDomain[]

  @@map("division")
}

model DivisionMembership {
  id         String   @id @default(cuid())
  userId     String
  divisionId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  division   Division @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, divisionId])
  @@map("division_membership")
}

model Invitation {
  id          String    @id @default(cuid())
  email       String
  role        Role      @default(field)
  divisionIds String[]  @default([])
  token       String    @unique
  invitedById String?
  acceptedAt  DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  @@index([email])
  @@map("invitation")
}

// ---------- Materials catalog (EAV) ----------

model MaterialUnit {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items MaterialItem[]

  @@map("material_unit")
}

model MaterialDomain {
  id          String   @id @default(cuid())
  divisionId  String
  division    Division @relation(fields: [divisionId], references: [id])
  segment     Segment
  name        String
  slug        String
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categories MaterialCategory[]

  @@unique([divisionId, segment, slug])
  @@index([divisionId])
  @@map("material_domain")
}

model MaterialCategory {
  id                       String             @id @default(cuid())
  domainId                 String
  domain                   MaterialDomain     @relation(fields: [domainId], references: [id])
  name                     String
  slug                     String
  description              String?
  sortOrder                Int                @default(0)
  isActive                 Boolean            @default(true)
  requiresManualPartNumber Boolean            @default(false)
  taxProfile               MaterialTaxProfile @default(TPP)
  stripeTaxCode            String?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  items       MaterialItem[]
  assignments MaterialAttributeAssignment[]

  @@unique([domainId, slug])
  @@index([domainId])
  @@map("material_category")
}

model MaterialAttribute {
  id        String                     @id @default(cuid())
  name      String
  slug      String                     @unique
  inputType MaterialAttributeInputType
  unit      String?
  isActive  Boolean                    @default(true)
  createdAt DateTime                   @default(now())
  updatedAt DateTime                   @updatedAt

  options     MaterialAttributeOption[]
  assignments MaterialAttributeAssignment[]
  values      MaterialItemAttributeValue[]

  @@map("material_attribute")
}

model MaterialAttributeOption {
  id          String            @id @default(cuid())
  attributeId String
  attribute   MaterialAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  value       String
  label       String
  sortOrder   Int               @default(0)
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  defaultFor MaterialAttributeAssignment[] @relation("DefaultOption")
  itemValues MaterialItemAttributeValue[]

  @@unique([attributeId, value])
  @@index([attributeId])
  @@map("material_attribute_option")
}

model MaterialAttributeAssignment {
  id                String                   @id @default(cuid())
  categoryId        String
  category          MaterialCategory         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  attributeId       String
  attribute         MaterialAttribute        @relation(fields: [attributeId], references: [id])
  isRequired        Boolean                  @default(false)
  isFilterable      Boolean                  @default(true)
  isVariantDefining Boolean                  @default(false)
  defaultOptionId   String?
  defaultOption     MaterialAttributeOption? @relation("DefaultOption", fields: [defaultOptionId], references: [id])
  sortOrder         Int                      @default(0)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  @@unique([categoryId, attributeId])
  @@index([categoryId])
  @@index([attributeId])
  @@map("material_attribute_assignment")
}

model MaterialItem {
  id             String              @id @default(cuid())
  categoryId     String
  category       MaterialCategory    @relation(fields: [categoryId], references: [id])
  unitId         String
  unit           MaterialUnit        @relation(fields: [unitId], references: [id])
  name           String
  laborUnits     Decimal             @default(0) @db.Decimal(12, 4)
  laborUnitNotes String?
  isConsumable   Boolean             @default(false)
  baseCost       Decimal?            @db.Decimal(12, 2)
  markupPct      Decimal?            @db.Decimal(6, 4)
  wasteFactorPct Decimal?            @db.Decimal(6, 4)
  supplier       String?
  notes          String?
  isActive       Boolean             @default(true)
  taxProfile     MaterialTaxProfile?
  stripeTaxCode  String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  values MaterialItemAttributeValue[]

  @@index([categoryId])
  @@index([unitId])
  @@map("material_item")
}

model MaterialItemAttributeValue {
  id          String                   @id @default(cuid())
  itemId      String
  item        MaterialItem             @relation(fields: [itemId], references: [id], onDelete: Cascade)
  attributeId String
  attribute   MaterialAttribute        @relation(fields: [attributeId], references: [id])
  optionId    String?
  option      MaterialAttributeOption? @relation(fields: [optionId], references: [id])
  valueText   String?
  valueNumber Decimal?                 @db.Decimal(18, 6)
  valueBool   Boolean?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@unique([itemId, attributeId])
  @@index([itemId])
  @@index([attributeId])
  @@map("material_item_attribute_value")
}
