// SPS Portal 2.0 — ops-tier schema (auth + org + materials catalog).
// Customer / lead PII lives in prisma/pii/schema.prisma (separate Neon project).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  power_user
  sales
  accounting
  field_supervisor
  field_tech
}

enum CapabilityEffect {
  ALLOW
  DENY
}

enum Segment {
  COMMERCIAL
  RESIDENTIAL
  STR
}

enum MaterialAttributeInputType {
  SELECT
  MULTISELECT
  TEXT
  NUMBER
  BOOLEAN
}

enum MaterialTaxProfile {
  REAL_PROPERTY
  TPP
}

enum WorkContext {
  INSTALL
  SERVICE
}

/// Billable rate column for labor engines (prompt 09).
enum LaborRateType {
  STANDARD
  AFTER_HOURS
  HOLIDAY
}

/// Complexity multiplier category (prompt 10).
enum ComplexityCategory {
  STRUCTURAL
  ACCESS
  COMPLIANCE
}

/// Recurring fee / SMA catalog (prompt 11).
enum BillingCycle {
  ANNUAL
  MONTHLY
}

enum RecurringFeeUnit {
  YEAR
  MONTH
}

enum RecurringFeeType {
  SMA_BASE_TIER
  SMA_SVM
  SMA_BANK_OF_HOURS
  MONTHLY_SERVICE
}

enum RateValueType {
  CURRENCY
  PERCENT
}

// ---------- Better-Auth core ----------

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  phone         String?
  role          Role     @default(power_user)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions             Session[]
  accounts             Account[]
  memberships          DivisionMembership[]
  capabilityOverrides  UserCapabilityOverride[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// ---------- Division layer ----------

model Division {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  segments  String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships             DivisionMembership[]
  materialDomains         MaterialDomain[]
  laborRateConfigs        LaborRateConfig[]
  laborPositions          LaborPosition[]
  complexityMultipliers   ComplexityMultiplier[]
  recurringFeeItems       RecurringFeeItem[]

  @@map("division")
}

model DivisionMembership {
  id         String   @id @default(cuid())
  userId     String
  divisionId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  division   Division @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, divisionId])
  @@map("division_membership")
}

model Invitation {
  id          String    @id @default(cuid())
  email       String
  role        Role      @default(field_tech)
  divisionIds String[]  @default([])
  token       String    @unique
  invitedById String?
  acceptedAt  DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  @@index([email])
  @@map("invitation")
}

// ---------- Capabilities (RBAC matrix) ----------

model Capability {
  id          String   @id
  label       String
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roleCapabilities RoleCapability[]
  userOverrides    UserCapabilityOverride[]

  @@map("capability")
}

model RoleCapability {
  id           String     @id @default(cuid())
  role         Role
  capabilityId String
  capability   Capability @relation(fields: [capabilityId], references: [id], onDelete: Cascade)
  allowed      Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([role, capabilityId])
  @@index([capabilityId])
  @@map("role_capability")
}

model UserCapabilityOverride {
  id           String           @id @default(cuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  capabilityId String
  capability   Capability       @relation(fields: [capabilityId], references: [id], onDelete: Cascade)
  effect       CapabilityEffect
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([userId, capabilityId])
  @@index([capabilityId])
  @@map("user_capability_override")
}

// ---------- Materials catalog (EAV) ----------

model MaterialUnit {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items MaterialItem[]

  @@map("material_unit")
}

model MaterialDomain {
  id          String   @id @default(cuid())
  divisionId  String
  division    Division @relation(fields: [divisionId], references: [id])
  segment     Segment
  name        String
  slug        String
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categories MaterialCategory[]

  @@unique([divisionId, segment, slug])
  @@index([divisionId])
  @@map("material_domain")
}

model MaterialCategory {
  id                       String             @id @default(cuid())
  domainId                 String
  domain                   MaterialDomain     @relation(fields: [domainId], references: [id])
  name                     String
  slug                     String
  description              String?
  sortOrder                Int                @default(0)
  isActive                 Boolean            @default(true)
  requiresManualPartNumber Boolean            @default(false)
  /// Per Ryan's classification (informed by SES v. Roberts) — see claude/prompts/05-materials-tax-code-linkage.md
  taxProfile               MaterialTaxProfile @default(REAL_PROPERTY)
  taxReviewed              Boolean            @default(false)
  stripeTaxCodeId          String?
  stripeTaxCode            StripeTaxCode?     @relation("CategoryMaterialTaxCode", fields: [stripeTaxCodeId], references: [id])
  laborInstallTaxCodeId    String?
  laborInstallTaxCode      StripeTaxCode?     @relation("CategoryLaborInstallTaxCode", fields: [laborInstallTaxCodeId], references: [id])
  laborServiceTaxCodeId    String?
  laborServiceTaxCode      StripeTaxCode?     @relation("CategoryLaborServiceTaxCode", fields: [laborServiceTaxCodeId], references: [id])
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  items       MaterialItem[]
  assignments MaterialAttributeAssignment[]

  @@unique([domainId, slug])
  @@index([domainId])
  @@index([taxReviewed])
  @@map("material_category")
}

model MaterialAttribute {
  id        String                     @id @default(cuid())
  name      String
  slug      String                     @unique
  inputType MaterialAttributeInputType
  unit      String?
  isActive  Boolean                    @default(true)
  createdAt DateTime                   @default(now())
  updatedAt DateTime                   @updatedAt

  options     MaterialAttributeOption[]
  assignments MaterialAttributeAssignment[]
  values      MaterialItemAttributeValue[]

  @@map("material_attribute")
}

model MaterialAttributeOption {
  id          String            @id @default(cuid())
  attributeId String
  attribute   MaterialAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  value       String
  label       String
  sortOrder   Int               @default(0)
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  defaultFor MaterialAttributeAssignment[] @relation("DefaultOption")
  itemValues MaterialItemAttributeValue[]

  @@unique([attributeId, value])
  @@index([attributeId])
  @@map("material_attribute_option")
}

model MaterialAttributeAssignment {
  id                String                   @id @default(cuid())
  categoryId        String
  category          MaterialCategory         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  attributeId       String
  attribute         MaterialAttribute        @relation(fields: [attributeId], references: [id])
  isRequired        Boolean                  @default(false)
  isFilterable      Boolean                  @default(true)
  isVariantDefining Boolean                  @default(false)
  defaultOptionId   String?
  defaultOption     MaterialAttributeOption? @relation("DefaultOption", fields: [defaultOptionId], references: [id])
  sortOrder         Int                      @default(0)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  @@unique([categoryId, attributeId])
  @@index([categoryId])
  @@index([attributeId])
  @@map("material_attribute_assignment")
}

model MaterialItem {
  id                    String              @id @default(cuid())
  categoryId            String
  category              MaterialCategory    @relation(fields: [categoryId], references: [id])
  unitId                String
  unit                  MaterialUnit        @relation(fields: [unitId], references: [id])
  name                  String
  laborUnits            Decimal             @default(0) @db.Decimal(12, 4)
  laborUnitNotes        String?
  isConsumable          Boolean             @default(false)
  baseCost              Decimal?            @db.Decimal(12, 2)
  markupPct             Decimal?            @db.Decimal(6, 4)
  wasteFactorPct        Decimal?            @db.Decimal(6, 4)
  supplier              String?
  notes                 String?
  isActive              Boolean             @default(true)
  taxProfile            MaterialTaxProfile?
  stripeTaxCodeId       String?
  stripeTaxCode         StripeTaxCode?      @relation("ItemMaterialTaxCode", fields: [stripeTaxCodeId], references: [id])
  laborInstallTaxCodeId String?
  laborInstallTaxCode   StripeTaxCode?      @relation("ItemLaborInstallTaxCode", fields: [laborInstallTaxCodeId], references: [id])
  laborServiceTaxCodeId String?
  laborServiceTaxCode   StripeTaxCode?      @relation("ItemLaborServiceTaxCode", fields: [laborServiceTaxCodeId], references: [id])
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  values MaterialItemAttributeValue[]

  @@unique([categoryId, name])
  @@index([categoryId])
  @@index([unitId])
  @@map("material_item")
}

/// Stripe product tax codes (reference data). Seeded from product_tax_codes.csv.
model StripeTaxCode {
  id                               String   @id
  name                             String
  description                      String   @db.Text
  type                             String
  performanceLocationRequirement   String
  createdAt                        DateTime @default(now())
  updatedAt                        DateTime @updatedAt

  categoryMaterial     MaterialCategory[]     @relation("CategoryMaterialTaxCode")
  categoryLaborInstall MaterialCategory[]     @relation("CategoryLaborInstallTaxCode")
  categoryLaborService MaterialCategory[]     @relation("CategoryLaborServiceTaxCode")
  itemMaterial         MaterialItem[]         @relation("ItemMaterialTaxCode")
  itemLaborInstall     MaterialItem[]         @relation("ItemLaborInstallTaxCode")
  itemLaborService     MaterialItem[]         @relation("ItemLaborServiceTaxCode")
  laborDefaults        LaborTaxCodeDefault[]

  @@map("stripe_tax_code")
}

/// Default labor Stripe tax code for (taxProfile, workContext).
/// Per Ryan's classification — see claude/prompts/05-materials-tax-code-linkage.md
model LaborTaxCodeDefault {
  id              String             @id @default(cuid())
  taxProfile      MaterialTaxProfile
  workContext     WorkContext
  stripeTaxCodeId String
  stripeTaxCode   StripeTaxCode      @relation(fields: [stripeTaxCodeId], references: [id])
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([taxProfile, workContext])
  @@map("labor_tax_code_default")
}

model MaterialItemAttributeValue {
  id          String                   @id @default(cuid())
  itemId      String
  item        MaterialItem             @relation(fields: [itemId], references: [id], onDelete: Cascade)
  attributeId String
  attribute   MaterialAttribute        @relation(fields: [attributeId], references: [id])
  optionId    String?
  option      MaterialAttributeOption? @relation(fields: [optionId], references: [id])
  valueText   String?
  valueNumber Decimal?                 @db.Decimal(18, 6)
  valueBool   Boolean?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@unique([itemId, attributeId])
  @@index([itemId])
  @@index([attributeId])
  @@map("material_item_attribute_value")
}

// ---------- Pricing catalog (labor rates — prompt 09) ----------

/// Global multipliers for a division+segment scope. Stored rates on LaborPosition
/// are authoritative at runtime; these document derivation / recomputeRates.
model LaborRateConfig {
  id                           String   @id @default(cuid())
  divisionId                   String
  division                     Division @relation(fields: [divisionId], references: [id])
  segment                      Segment
  burdenMultiplier             Decimal  @db.Decimal(6, 4)
  commercialBillingMultiplier  Decimal  @db.Decimal(6, 4)
  afterHoursMultiplier         Decimal  @db.Decimal(6, 4)
  holidayMultiplier            Decimal  @db.Decimal(6, 4)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  @@unique([divisionId, segment])
  @@index([divisionId])
  @@map("labor_rate_config")
}

/// Per-role sell/cost rates for a division+segment. context=INSTALL → quoted blend;
/// context=SERVICE → service-ticket engine only (never in quoted distribution).
model LaborPosition {
  id                   String      @id @default(cuid())
  divisionId           String
  division             Division    @relation(fields: [divisionId], references: [id])
  segment              Segment
  title                String
  sku                  String
  baseHourlyRate       Decimal     @db.Decimal(12, 2)
  actualCostOfLabor    Decimal     @db.Decimal(12, 2)
  standardBillingRate  Decimal     @db.Decimal(12, 2)
  afterHoursRate       Decimal     @db.Decimal(12, 2)
  holidayRate          Decimal     @db.Decimal(12, 2)
  quotedAllocationPct  Decimal     @db.Decimal(5, 2)
  context              WorkContext
  sortOrder            Int         @default(0)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  @@unique([divisionId, segment, sku])
  @@index([divisionId])
  @@index([divisionId, segment, context])
  @@map("labor_position")
}

/// Hours-only complexity adders (prompt 10). Never multiply dollars — only baseHours.
model ComplexityMultiplier {
  id               String              @id @default(cuid())
  divisionId       String
  division         Division            @relation(fields: [divisionId], references: [id])
  segment          Segment
  name             String
  slug             String
  category         ComplexityCategory
  modificationRate Decimal             @db.Decimal(5, 4)
  description      String              @db.Text
  isActive         Boolean             @default(true)
  sortOrder        Int                 @default(0)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@unique([divisionId, segment, slug])
  @@index([divisionId])
  @@index([divisionId, segment])
  @@map("complexity_multiplier")
}

/// Recurring fee catalog (prompt 11). SMA tiers/SVM/BOH vs MONTHLY_SERVICE are separate engines.
/// PERCENT rows (SVM) store rates as decimals (0.1560); CURRENCY as dollars.
/// Bank of Hours dollar columns are placeholders — sell rate is derived live from Tech 1&2.
model RecurringFeeItem {
  id                 String            @id @default(cuid())
  divisionId         String
  division           Division          @relation(fields: [divisionId], references: [id])
  segment            Segment
  sku                String
  description        String
  unit               RecurringFeeUnit
  baseCost           Decimal           @db.Decimal(12, 4)
  directPurchaseRate Decimal           @db.Decimal(12, 4)
  smaBundledRate     Decimal           @db.Decimal(12, 4)
  billingCycle       BillingCycle
  feeType            RecurringFeeType
  valueType          RateValueType
  systemValueMin     Decimal?          @db.Decimal(12, 2)
  systemValueMax     Decimal?          @db.Decimal(12, 2)
  notes              String            @db.Text
  isActive           Boolean           @default(true)
  sortOrder          Int               @default(0)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@unique([divisionId, segment, sku])
  @@index([divisionId])
  @@index([divisionId, segment, feeType])
  @@map("recurring_fee_item")
}
