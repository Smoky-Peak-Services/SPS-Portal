// SPS Portal 2.0 — PII-tier schema (lead ingest + division replication).
// CRM Customer/Contact/ServiceLocation deferred until that phase.
// Generate: npm run db:generate:pii

generator client {
  provider = "prisma-client-js"
  output   = "../generated/pii"
}

datasource db {
  provider = "postgresql"
}

enum LeadSource {
  WEBSITE
  PHONE
  REFERRAL
  WALK_IN
  OTHER
}

enum LeadStatus {
  INQUIRY
  SITE_VISIT
  ESTIMATE_SENT
  APPROVED
  WON
  LOST
  DISQUALIFIED
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
  SMS
  MEETING
  STATUS_CHANGE
}

// Division metadata replicated from ops DB (no cross-DB FK).
model Division {
  id        String   @id
  slug      String   @unique
  name      String
  segments  String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leads      Lead[]
  ingestKeys IngestKey[]

  @@map("division")
}

model Lead {
  id          String     @id @default(cuid())
  divisionId  String
  /// Org Division FK (ops-replicated). Named to avoid clash with form `division` text.
  orgDivision Division   @relation(fields: [divisionId], references: [id])
  name        String
  email       String?
  phone       String?
  /// Form "Division" / inquiry-type selection (not the org FK).
  division    String?
  /// Submitter company name. Ingest defaults blank/missing to "Residential".
  company     String?
  message     String?
  source      LeadSource @default(WEBSITE)
  status      LeadStatus @default(INQUIRY)
  budget      String?
  timeline    String?
  closedAt    DateTime?
  activities  Activity[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([divisionId])
  @@index([status])
  @@index([email])
  @@map("lead")
}

model Activity {
  id          String       @id @default(cuid())
  type        ActivityType
  body        String?
  meta        Json?
  leadId      String?
  lead        Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdById String?
  createdAt   DateTime     @default(now())

  @@index([leadId])
  @@map("activity")
}

model IngestKey {
  id         String    @id @default(cuid())
  divisionId String
  division   Division  @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  label      String
  keyHash    String    @unique
  keyPrefix  String
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([divisionId])
  @@map("ingest_key")
}
